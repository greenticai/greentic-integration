{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Put secret input",
  "type": "object",
  "properties": {
    "key": {"type": "string", "minLength": 1},
    "value": {
      "type": ["string", "number", "boolean", "object", "array"],
      "description": "Secret payload to store"
    }
  },
  "required": ["key", "value"],
  "additionalProperties": false
}

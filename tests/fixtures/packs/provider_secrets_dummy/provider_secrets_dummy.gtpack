{
  "id": "provider_secrets_dummy",
  "name": "Dummy provider-core secrets pack",
  "version": "0.0.1",
  "kind": "provider",
  "provider_core": {
    "provider_type": "secrets",
    "capabilities": ["put", "get"],
    "operations": {

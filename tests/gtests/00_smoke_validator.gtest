@set PACK_DIR=${WORK_DIR}/demo-pack
@set COMPONENT_DIR=${WORK_DIR}/demo-comp
@set FLOW_PATH=${PACK_DIR}/flows/main.ygtc
@set ARTIFACTS_DIR=${WORK_DIR}/artifacts
@set PACK_COMPONENT_ID=ai.greentic.component-echo
greentic-pack new --dir ${PACK_DIR} demo-pack
python3 - <<'PY'
import json
from pathlib import Path

create_answers = {
    "wizard_id": "greentic-component.wizard.run",
    "schema_id": "greentic-component.wizard.run",
    "schema_version": "1.0.0",
    "answers": {
        "mode": "create",
        "fields": {
            "component_name": "demo-comp",
            "output_dir": "${COMPONENT_DIR}",
            "advanced_setup": False,
            "abi_version": "0.6.0",
            "operation_names": "handle_message",
            "filesystem_mode": "none",
            "telemetry_scope": "node",
        },
    },
}
Path("${WORK_DIR}/component-create.answers.json").write_text(
    json.dumps(create_answers, indent=2, sort_keys=True)
)
PY
greentic-component wizard apply --answers ${WORK_DIR}/component-create.answers.json
test -f ${COMPONENT_DIR}/component.manifest.json
mkdir -p ${PACK_DIR}/components/ai.greentic.component-echo
cp ${REPO_ROOT}/crates/test-packs/echo-pack/components/ai.greentic.component-echo/component_echo.wasm ${PACK_DIR}/components/ai.greentic.component-echo/component.wasm
cp ${REPO_ROOT}/crates/test-components/component-echo/component.manifest.json ${PACK_DIR}/components/ai.greentic.component-echo/component.manifest.json
python3 - <<'PY'
import json
from pathlib import Path

manifest_path = Path("${PACK_DIR}/components/ai.greentic.component-echo/component.manifest.json")
data = json.loads(manifest_path.read_text())
wasm = data.get("wasm")
if isinstance(wasm, str):
    data["wasm"] = "component.wasm"
elif isinstance(wasm, dict):
    if "path" in wasm:
        if isinstance(wasm["path"], dict):
            if "path" in wasm["path"]:
                wasm["path"]["path"] = "component.wasm"
            if "file" in wasm["path"]:
                wasm["path"]["file"] = "component.wasm"
        else:
            wasm["path"] = "component.wasm"
    elif "file" in wasm:
        wasm["file"] = "component.wasm"
    data["wasm"] = wasm
manifest_path.write_text(json.dumps(data, indent=2, sort_keys=True))
PY
mkdir -p ${PACK_DIR}/components/ai.greentic.component-echo/target/wasm32-wasip2/release
cp ${PACK_DIR}/components/ai.greentic.component-echo/component.wasm ${PACK_DIR}/components/ai.greentic.component-echo/target/wasm32-wasip2/release/component_echo.wasm

cat > ${FLOW_PATH} <<'YAML'
id: main
type: messaging
start: demo
parameters: {}
tags: []
schema_version: 2
entrypoints: {}
nodes:
  demo:
    routing: out
    ai.greentic.component-echo:
      operation: messaging.send
      channel: webchat
      id: demo-1
      metadata:
        trace_id: demo-trace
      session_id: sess-demo
      text: hello
YAML
python3 - <<'PY'
import hashlib
import json
from pathlib import Path

flow_path = Path("${FLOW_PATH}")
wasm_path = Path("${PACK_DIR}/components/ai.greentic.component-echo/component.wasm")
digest = hashlib.sha256(wasm_path.read_bytes()).hexdigest()
relative_wasm = "../components/ai.greentic.component-echo/component.wasm"

resolve = {
    "schema_version": 1,
    "flow": flow_path.name,
    "nodes": {
        "demo": {
            "source": {
                "kind": "local",
                "path": relative_wasm,
                "digest": f"sha256:{digest}",
            }
        }
    },
}

summary = {
    "schema_version": 1,
    "flow": flow_path.name,
    "nodes": {
        "demo": {
            "component_id": "ai.greentic.component-echo",
            "source": {
                "kind": "local",
                "path": relative_wasm,
            },
            "digest": f"sha256:{digest}",
        }
    },
}

resolve_path = flow_path.with_name(flow_path.name + ".resolve.json")
summary_path = flow_path.with_name(flow_path.name + ".resolve.summary.json")
resolve_path.write_text(json.dumps(resolve, indent=2, sort_keys=True))
summary_path.write_text(json.dumps(summary, indent=2, sort_keys=True))
PY

greentic-pack update --in ${PACK_DIR}
cp ${REPO_ROOT}/crates/test-packs/echo-pack/components/ai.greentic.component-echo/component_echo.wasm ${PACK_DIR}/components/ai.greentic.component-echo/component.wasm
cp ${REPO_ROOT}/crates/test-components/component-echo/component.manifest.json ${PACK_DIR}/components/ai.greentic.component-echo/component.manifest.json
python3 - <<'PY'
import json
from pathlib import Path

manifest_path = Path("${PACK_DIR}/components/ai.greentic.component-echo/component.manifest.json")
data = json.loads(manifest_path.read_text())
wasm = data.get("wasm")
if isinstance(wasm, str):
    data["wasm"] = "component.wasm"
elif isinstance(wasm, dict):
    if "path" in wasm:
        if isinstance(wasm["path"], dict):
            if "path" in wasm["path"]:
                wasm["path"]["path"] = "component.wasm"
            if "file" in wasm["path"]:
                wasm["path"]["file"] = "component.wasm"
        else:
            wasm["path"] = "component.wasm"
    elif "file" in wasm:
        wasm["file"] = "component.wasm"
    data["wasm"] = wasm
manifest_path.write_text(json.dumps(data, indent=2, sort_keys=True))
PY
mkdir -p ${PACK_DIR}/components/ai.greentic.component-echo/target/wasm32-wasip2/release
cp ${PACK_DIR}/components/ai.greentic.component-echo/component.wasm ${PACK_DIR}/components/ai.greentic.component-echo/target/wasm32-wasip2/release/component_echo.wasm
greentic-pack resolve --in ${PACK_DIR} --offline
greentic-pack build --in ${PACK_DIR} --allow-oci-tags --no-update
greentic-pack doctor --in ${PACK_DIR} --allow-oci-tags
test -f ${PACK_DIR}/dist/demo-pack.gtpack


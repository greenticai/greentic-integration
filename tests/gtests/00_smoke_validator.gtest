@set PACK_DIR=${WORK_DIR}/demo-pack
@set COMPONENT_DIR=${WORK_DIR}/demo-comp
@set FLOW_PATH=${PACK_DIR}/flows/main.ygtc
@set ARTIFACTS_DIR=${WORK_DIR}/artifacts
@env CARGO_NET_OFFLINE=true

greentic-pack new --dir ${PACK_DIR} demo-pack
greentic-component new --name demo-comp --path ${COMPONENT_DIR} --non-interactive --no-git --no-check
greentic-component build --manifest ${COMPONENT_DIR}/component.manifest.json
greentic-component doctor ${COMPONENT_DIR}/component.manifest.json
mkdir -p ${PACK_DIR}/components/ai.greentic.demo-comp
cp ${COMPONENT_DIR}/target/wasm32-wasip2/release/demo_comp.wasm ${PACK_DIR}/components/ai.greentic.demo-comp/component.wasm
cp ${COMPONENT_DIR}/component.manifest.json ${PACK_DIR}/components/ai.greentic.demo-comp/component.manifest.json
python3 - <<'PY'
import json
from pathlib import Path

manifest_path = Path("${PACK_DIR}/components/ai.greentic.demo-comp/component.manifest.json")
data = json.loads(manifest_path.read_text())
wasm = data.get("wasm")
if isinstance(wasm, str):
    data["wasm"] = "component.wasm"
elif isinstance(wasm, dict):
    if "path" in wasm:
        if isinstance(wasm["path"], dict):
            if "path" in wasm["path"]:
                wasm["path"]["path"] = "component.wasm"
            if "file" in wasm["path"]:
                wasm["path"]["file"] = "component.wasm"
        else:
            wasm["path"] = "component.wasm"
    elif "file" in wasm:
        wasm["file"] = "component.wasm"
    data["wasm"] = wasm
manifest_path.write_text(json.dumps(data, indent=2, sort_keys=True))
PY
mkdir -p ${PACK_DIR}/components/ai.greentic.demo-comp/target/wasm32-wasip2/release
cp ${PACK_DIR}/components/ai.greentic.demo-comp/component.wasm ${PACK_DIR}/components/ai.greentic.demo-comp/target/wasm32-wasip2/release/demo_comp.wasm

cat > ${FLOW_PATH} <<'YAML'
id: main
type: messaging
start: demo
parameters: {}
tags: []
schema_version: 2
entrypoints: {}
nodes:
  demo:
    component:
      id: ai.greentic.demo-comp
      operation: handle_message
      input: "hello"
    routing: out
YAML
python3 - <<'PY'
import hashlib
import json
from pathlib import Path

flow_path = Path("${FLOW_PATH}")
wasm_path = Path("${PACK_DIR}/components/ai.greentic.demo-comp/component.wasm")
digest = hashlib.sha256(wasm_path.read_bytes()).hexdigest()
relative_wasm = "../components/ai.greentic.demo-comp/component.wasm"

resolve = {
    "schema_version": 1,
    "flow": flow_path.name,
    "nodes": {
        "demo": {
            "source": {
                "kind": "local",
                "path": relative_wasm,
                "digest": f"sha256:{digest}",
            }
        }
    },
}

summary = {
    "schema_version": 1,
    "flow": flow_path.name,
    "nodes": {
        "demo": {
            "component_id": "ai.greentic.demo-comp",
            "source": {
                "kind": "local",
                "path": relative_wasm,
            },
            "digest": f"sha256:{digest}",
        }
    },
}

resolve_path = flow_path.with_name(flow_path.name + ".resolve.json")
summary_path = flow_path.with_name(flow_path.name + ".resolve.summary.json")
resolve_path.write_text(json.dumps(resolve, indent=2, sort_keys=True))
summary_path.write_text(json.dumps(summary, indent=2, sort_keys=True))
PY

greentic-pack update --in ${PACK_DIR}
cp ${COMPONENT_DIR}/target/wasm32-wasip2/release/demo_comp.wasm ${PACK_DIR}/components/ai.greentic.demo-comp/component.wasm
cp ${COMPONENT_DIR}/component.manifest.json ${PACK_DIR}/components/ai.greentic.demo-comp/component.manifest.json
python3 - <<'PY'
import json
from pathlib import Path

manifest_path = Path("${PACK_DIR}/components/ai.greentic.demo-comp/component.manifest.json")
data = json.loads(manifest_path.read_text())
wasm = data.get("wasm")
if isinstance(wasm, str):
    data["wasm"] = "component.wasm"
elif isinstance(wasm, dict):
    if "path" in wasm:
        if isinstance(wasm["path"], dict):
            if "path" in wasm["path"]:
                wasm["path"]["path"] = "component.wasm"
            if "file" in wasm["path"]:
                wasm["path"]["file"] = "component.wasm"
        else:
            wasm["path"] = "component.wasm"
    elif "file" in wasm:
        wasm["file"] = "component.wasm"
    data["wasm"] = wasm
manifest_path.write_text(json.dumps(data, indent=2, sort_keys=True))
PY
mkdir -p ${PACK_DIR}/components/ai.greentic.demo-comp/target/wasm32-wasip2/release
cp ${PACK_DIR}/components/ai.greentic.demo-comp/component.wasm ${PACK_DIR}/components/ai.greentic.demo-comp/target/wasm32-wasip2/release/demo_comp.wasm
greentic-pack resolve --in ${PACK_DIR} --offline
greentic-pack build --in ${PACK_DIR} --allow-oci-tags --no-update
greentic-pack doctor --in ${PACK_DIR} --allow-oci-tags
test -f ${PACK_DIR}/dist/demo-pack.gtpack

greentic-runner-cli --pack ${PACK_DIR}/dist/demo-pack.gtpack --input "\"hello\"" --artifacts-dir ${ARTIFACTS_DIR} --json
test -f ${ARTIFACTS_DIR}/transcript.jsonl
sh -c 'rg -q "ai.greentic.demo-comp" ${ARTIFACTS_DIR}/transcript.jsonl || grep -q "ai.greentic.demo-comp" ${ARTIFACTS_DIR}/transcript.jsonl'

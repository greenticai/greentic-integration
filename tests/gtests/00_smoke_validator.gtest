@set PACK_DIR=${WORK_DIR}/demo-pack
@set COMPONENT_DIR=${PACK_DIR}/components/demo-comp
@set FLOW_PATH=${PACK_DIR}/flows/main.ygtc
@set ARTIFACTS_DIR=${WORK_DIR}/artifacts

greentic-pack new --dir ${PACK_DIR} demo-pack
greentic-component new --name demo-comp --path ${COMPONENT_DIR} --non-interactive --no-git
greentic-component build --manifest ${COMPONENT_DIR}/component.manifest.json
greentic-component doctor ${COMPONENT_DIR}/component.manifest.json
mkdir -p ${PACK_DIR}/components/ai.greentic.demo-comp
cp ${COMPONENT_DIR}/target/wasm32-wasip2/release/demo_comp.wasm ${PACK_DIR}/components/ai.greentic.demo-comp/component.wasm
cp ${COMPONENT_DIR}/component.manifest.json ${PACK_DIR}/components/ai.greentic.demo-comp/component.manifest.json
python - <<'PY'
import json
from pathlib import Path

manifest_path = Path("${PACK_DIR}/components/ai.greentic.demo-comp/component.manifest.json")
data = json.loads(manifest_path.read_text())
wasm = data.get("wasm")
if isinstance(wasm, str):
    data["wasm"] = "component.wasm"
elif isinstance(wasm, dict):
    if "path" in wasm:
        wasm["path"] = "component.wasm"
    elif "file" in wasm:
        wasm["file"] = "component.wasm"
manifest_path.write_text(json.dumps(data, indent=2, sort_keys=True))
PY

greentic-flow new --flow ${FLOW_PATH} --id main --type messaging --force
greentic-flow add-step --flow ${FLOW_PATH} --node-id demo --local-wasm ${PACK_DIR}/components/ai.greentic.demo-comp/component.wasm --operation handle_message --payload "\"hello\"" --routing-out --manifest ${PACK_DIR}/components/ai.greentic.demo-comp/component.manifest.json
greentic-flow add-step --flow ${FLOW_PATH} --after demo --node-id template --component oci://ghcr.io/greentic-ai/components/templates:latest --operation render --payload "{\"template\":\"Result: {{node.demo}}\"}" --routing-out
greentic-flow update-step --flow ${FLOW_PATH} --step demo --routing-next template

greentic-pack update --in ${PACK_DIR}
greentic-pack build --in ${PACK_DIR} --allow-oci-tags
greentic-pack doctor --in ${PACK_DIR} --allow-oci-tags
greentic-integration-validator file exists ${PACK_DIR}/dist/demo-pack.gtpack

greentic-runner-cli --pack ${PACK_DIR}/dist/demo-pack.gtpack --input "\"hello\"" --artifacts-dir ${ARTIFACTS_DIR} --json
greentic-integration-validator file exists ${ARTIFACTS_DIR}/transcript.jsonl
greentic-integration-validator file contains ${ARTIFACTS_DIR}/transcript.jsonl "demo-comp::handle_message"

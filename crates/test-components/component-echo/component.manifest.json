  "dev_flows": {
    "custom": {
      "format": "flow-ir-json",
      "graph": {
        "description": "Auto-generated custom config for ai.greentic.component-echo",
        "id": "ai.greentic.component-echo.custom",
        "kind": "component-config",
        "nodes": {
          "ask_config": {
            "questions": {
              "fields": [
                {
                  "id": "attachments",
                  "prompt": "Attachments:",
                  "type": "string"
                },
                {
                  "id": "channel",
                  "prompt": "Channel:",
                  "type": "string"
                },
                {
                  "id": "id",
                  "prompt": "Id:",
                  "type": "string"
                },
                {
                  "id": "metadata",
                  "prompt": "Metadata:",
                  "type": "string"
                },
                {
                  "id": "session_id",
                  "prompt": "Session Id:",
                  "type": "string"
                },
                {
                  "id": "tenant",
                  "prompt": "Tenant:",
                  "type": "string"
                },
                {
                  "id": "text",
                  "prompt": "Text:",
                  "type": "string"
                }
              ]
            },
            "routing": [
              {
                "to": "emit_config"
              }
            ]
          },
          "emit_config": {
            "template": "{\n  \"node_id\": \"component-echo\",\n  \"node\": {\n    \"messaging.send\": {\n      \"input\": {\n        \"attachments\": \"{{state.attachments}}\",\n        \"channel\": \"{{state.channel}}\",\n        \"id\": \"{{state.id}}\",\n        \"metadata\": \"{{state.metadata}}\",\n        \"session_id\": \"{{state.session_id}}\",\n        \"tenant\": \"{{state.tenant}}\",\n        \"text\": \"{{state.text}}\"\n      }\n    },\n    \"routing\": [\n      { \"to\": \"NEXT_NODE_PLACEHOLDER\" }\n    ]\n  }\n}"
          }
        }
      }
    },
    "default": {
      "format": "flow-ir-json",
      "graph": {
        "description": "Auto-generated default config for ai.greentic.component-echo",
        "id": "ai.greentic.component-echo.default",
